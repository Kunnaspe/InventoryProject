# Django Settings
# A placeholder is used for development. For production, generate a new secret key:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-production-secret-key-here

# Set to True for development, False for production
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts (defaults to localhost,127.0.0.1)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted origins for CSRF (required for HTTPS via CloudFront)
# Example: https://dxxxxxxxxxxxx.cloudfront.net
CSRF_TRUSTED_ORIGINS=

# Database Configuration (optional - defaults to SQLite if not set)
# Uncomment and configure for MySQL/MariaDB:
# DB_HOST=your-database-host
# DB_NAME=your-database-name
# DB_USER=your-database-user
# DB_PASSWORD=your-database-password
# DB_PORT=3306
# DB_SSL_CA=/home/ec2-user/InventoryProject/rds-ca.pem

# ─── AWS Cognito OAuth / OIDC Settings ────────────────────────────────────────
#
# These are required for the OAuth login flow. Obtain them from the AWS Console:
#   1. Go to Cognito > User Pools > <your pool> > App Integration > App clients
#   2. Copy the App client ID and App client secret below
#   3. Build COGNITO_SERVER_URL using the format shown below
#
# App Client ID (from Cognito App Client settings)
COGNITO_CLIENT_ID=your-cognito-app-client-id

# App Client Secret (from Cognito App Client settings)
COGNITO_CLIENT_SECRET=your-cognito-app-client-secret

# OIDC issuer URL — format: https://cognito-idp.<region>.amazonaws.com/<user_pool_id>
# Example: https://cognito-idp.ap-southeast-2.amazonaws.com/ap-southeast-2_AbCdEfGhI
COGNITO_SERVER_URL=https://cognito-idp.<region>.amazonaws.com/<user_pool_id>
#
# Callback URL registered in Cognito App Client:
#   https://<cloudfront-domain>/callback
# This redirects to /accounts/oidc/cognito/login/callback/ internally.
# ──────────────────────────────────────────────────────────────────────────────
